{
  "name": "quorum",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "description": "Quorum — self-hosted Discord-аналог для близкого круга (desktop)",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:server": "pnpm --filter @quorum/server dev",
    "dev:desktop": "pnpm --filter @quorum/desktop tauri:dev",
    "dev:desktop-web": "pnpm --filter @quorum/desktop dev",
    "build:shared": "pnpm --filter @quorum/shared build",
    "build:server": "pnpm --filter @quorum/server build",
    "build:desktop": "pnpm --filter @quorum/desktop tauri:build",
    "test": "pnpm -r --if-present test",
    "test:watch": "pnpm -r --if-present test:watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --if-present typecheck",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  }
}
