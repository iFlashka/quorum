# Скопируй в .env.prod, заполни и НЕ КОММИТЬ. .env.prod в .gitignore.

# Домены, на которые Caddy получит TLS через Let's Encrypt.
QUORUM_DOMAIN=quorum.example.com
LIVEKIT_DOMAIN=lk.example.com

# Публичный hostname/IP coturn'а — этот URL клиенты используют как ICE-сервер.
# Обычно совпадает с QUORUM_DOMAIN, но coturn UDP-порты открыты напрямую (host network).
COTURN_PUBLIC_HOST=quorum.example.com

# PostgreSQL — сгенерируй: openssl rand -hex 32
POSTGRES_PASSWORD=

# JWT — каждый минимум 48 base64-символов: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# coturn shared-secret для time-limited TURN creds. Должен совпадать с
# infra/coturn/turnserver.prod.conf::static-auth-secret.
# Сгенерируй: openssl rand -hex 32
TURN_SHARED_SECRET=

# LiveKit — должны совпадать с livekit/livekit.prod.yaml::keys.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
