{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quorum",
  "version": "0.0.1",
  "identifier": "app.quorum.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm --filter @quorum/desktop dev",
    "beforeBuildCommand": "pnpm --filter @quorum/desktop build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Quorum",
        "width": 1280,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "SocialNetworking",
    "shortDescription": "Quorum — self-hosted чат для близкого круга",
    "longDescription": "Self-hosted Discord-аналог для 5–10 близких друзей. Подключается к собственному серверу Quorum."
  },
  "plugins": {
    "//updater": "Заглушка фазы 0. В фазе 7: запустить `pnpm --filter @quorum/desktop tauri signer generate -- -w ~/.tauri/quorum.key`, public подложить в pubkey, private — в GitHub Secrets как TAURI_SIGNING_PRIVATE_KEY. См. .claude/memory/project_auto_update.md.",
    "updater": {
      "active": false,
      "pubkey": "",
      "endpoints": [
        "https://github.com/OWNER/REPO/releases/latest/download/latest.json"
      ]
    }
  }
}
