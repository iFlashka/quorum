{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quorum",
  "version": "0.0.1",
  "identifier": "app.quorum.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:4422",
    "beforeDevCommand": "pnpm --filter @quorum/desktop dev",
    "beforeBuildCommand": "pnpm --filter @quorum/desktop build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Quorum",
        "width": 1280,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "SocialNetworking",
    "shortDescription": "Quorum — self-hosted чат для близкого круга",
    "longDescription": "Self-hosted Discord-аналог для 5–10 близких друзей. Подключается к собственному серверу Quorum."
  },
  "plugins": {
    "updater": {
      "//": "Public key — base64 minisign-format. Приватный лежит в .tauri-keys/ (gitignored), для CI копируется в GitHub Secrets как TAURI_SIGNING_PRIVATE_KEY. Endpoint placeholder OWNER/REPO заменить при деплое.",
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ4QUJERjU4RjM3RjlDQUEKUldTcW5IL3pXTityU0NET2FSVlgwRnlQZ0E4M1RFbWRZdkVoNU9uL05JSEREYXk0TkxLZnVXYSsK",
      "endpoints": [
        "https://github.com/OWNER/REPO/releases/latest/download/latest.json"
      ]
    }
  }
}
