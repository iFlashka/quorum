{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Базовые capabilities для главного окна Quorum",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-is-maximized",
    "core:window:allow-start-dragging",
    "core:event:default",
    "os:default",
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-delete",
    "store:allow-save",
    "store:allow-load"
  ]
}
