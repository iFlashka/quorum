NODE_ENV=development
HOST=0.0.0.0
PORT=4421
LOG_LEVEL=debug

# PostgreSQL — поднимается локально через `pnpm infra:up`
DATABASE_URL=postgres://quorum:quorum_dev@localhost:5432/quorum

# Redis — для presence/pub-sub в фазе 2; в фазе 1 не используется, но поле уже валидируется.
REDIS_URL=redis://localhost:6379

# JWT-секреты. В деве — любые произвольные строки длиной >=32. В проде — сгенерировать и положить в env.
# Генерация:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=dev_access_secret_dev_access_secret_change_me_____
JWT_REFRESH_SECRET=dev_refresh_secret_dev_refresh_secret_change_me___

# Время жизни токенов (формат ms-style: "15m", "30d"; см. https://github.com/vercel/ms)
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
